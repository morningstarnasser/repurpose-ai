# Authentication (NextAuth v5)
AUTH_URL=http://localhost:3000
AUTH_SECRET=          # openssl rand -hex 32
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=       # Google OAuth Client ID
AUTH_GOOGLE_SECRET=   # Google OAuth Client Secret

# Apple Sign In
AUTH_APPLE_ID=        # Apple Service ID
APPLE_TEAM_ID=        # Apple Developer Team ID
APPLE_KEY_ID=         # Apple Sign In Key ID
APPLE_PRIVATE_KEY=    # Apple .p8 private key (single line with \n)

# AI Providers
NVIDIA_NIM_API_KEY=   # NVIDIA NIM API key (primary)
DEEPSEEK_API_KEY=     # DeepSeek API key (fallback)

# Database (Neon PostgreSQL)
DATABASE_URL=         # postgresql://...

# Stripe
STRIPE_SECRET_KEY=    # sk_...
STRIPE_PUBLISHABLE_KEY= # pk_...
STRIPE_WEBHOOK_SECRET=   # whsec_...
STRIPE_PRO_PRICE_ID=     # price_...

# Blog API (n8n webhook auth)
BLOG_API_SECRET=      # openssl rand -hex 32

# Email (Resend)
RESEND_API_KEY=       # Resend API key

# Cron (Vercel)
CRON_SECRET=          # openssl rand -hex 32

# Admin
ADMIN_EMAIL=          # admin user email

# Sentry (Error Tracking)
SENTRY_DSN=                # https://xxx@xxx.ingest.de.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=    # same as SENTRY_DSN
SENTRY_AUTH_TOKEN=         # sntrys_...
